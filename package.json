{
  "name": "sofareinigung-zuerich",
  "version": "1.3.1",
  "type": "module",
  "description": "Dieses Repo enthält den Code für die Webseite sofareinigung-zuerich.ch",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "dev": "nodemon app.js",
    "docker:build": "docker build . -t sofareinigung-zuerich",
    "docker:run": "docker run --rm --name sofareinigung-zuerich -p 8080:8080 --env-file ./docker.env sofareinigung-zuerich",
    "docker:stop": "docker stop sofareinigung-zuerich",
    "docker:tag": "docker tag sofareinigung-zuerich timond3v/sofareinigung-zuerich",
    "docker:push": "docker push timond3v/sofareinigung-zuerich",
    "docker:buildx": "docker buildx build --platform linux/amd64,linux/arm64 . -t sofareinigung-zuerich"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Timon-D3v/sofareinigung-zuerich"
  },
  "author": "Timon Fiedler",
  "license": "MIT",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "body-parser": "^2.2.2",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "ejs": "^4.0.1",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "imagekit": "^6.0.0",
    "mysql2": "^3.18.2",
    "node-mailjet": "^6.0.11",
    "timonjs": "2.0.5"
  },
  "devDependencies": {
    "nodemon": "^3.1.7"
  }
}
